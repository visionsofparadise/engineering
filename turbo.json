{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "./tsconfig.json"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "check"],
      "inputs": ["src/**", "./tsconfig.json", "./package.json"],
      "outputs": ["dist/**"]
    },
    "unit": {
      "dependsOn": ["check"]
    },
    "integration": {
      "dependsOn": ["build"]
    },
    "start": {},
    "lint": {
      "dependsOn": []
    }
  }
}
