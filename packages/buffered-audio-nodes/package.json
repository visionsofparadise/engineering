{
  "name": "@e9g/buffered-audio-nodes",
  "version": "0.7.2",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "buffered-audio-nodes": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Matt Cavender",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/visionsofparadise/engineering",
    "directory": "packages/buffered-audio-nodes"
  },
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "check:verbose": "concurrently \"eslint .\" \"tsc --noEmit\"",
    "lint": "eslint . --fix --cache --format ../../agent-eslint.js",
    "lint:verbose": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsup",
    "docs": "tsx scripts/generate-docs.ts",
    "unit": "vitest run unit",
    "integration": "vitest run integration --fileParallelism=false",
    "benchmark": "vitest run benchmark --fileParallelism=false"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "concurrently": "*",
    "tsup": "^8.0.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@e9g/buffered-audio-nodes-core": "0.4.0",
    "@e9g/buffered-audio-nodes-utils": "0.3.0",
    "bufferfy": "^4.0.3",
    "commander": "^14.0.3",
    "tsx": "^4.21.0",
    "wavefile": "^11.0.0",
    "zod": "^4.3.6"
  }
