{
  "name": "@e9g/spectral-display",
  "version": "0.1.6",
  "description": "WebGPU audio spectrogram and waveform visualization",
  "keywords": ["webgpu", "spectrogram", "waveform", "audio", "visualization"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "author": "Matt Cavender",
  "license": "ISC",
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "check:verbose": "concurrently \"eslint .\" \"tsc --noEmit\"",
    "lint": "eslint . --fix --cache --format ../../agent-eslint.js",
    "lint:verbose": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsup",
    "unit": "vitest run unit"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
